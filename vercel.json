{
  "builds": [
    {
      "src": "carecure/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    }
  ],
  "routes": [
    {
      "src": "/src/(.*)",
      "dest": "core/static/$1"
    },
    {
      "src": "(.*)",
      "dest": "carecure/wsgi.py"
    }
  ]
}
